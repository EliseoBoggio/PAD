{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=municipalidad.db"
  },
  "Jwt": {
    "Key": "InsecureDevelopmentKey123!",
    "Issuer": "Municipalidad",
    "Audience": "MunicipalidadClients"
  },
  "Clients": {
    "DNRPA": {
      "BaseUrl": "https://api.dnrpa.gob.ar",
      "ApiKey": "replace-with-real-key"
    },
    "ARCA": {
      "BaseUrl": "https://api.arca.gob.ar",
      "Token": "replace-with-real-token"
    },
    "PagoFacil": {
      "BaseUrl": "https://api.pagofacil.com",
      "CommerceId": "demo-commerce",
      "ApiKey": "replace-with-real-key"
    },
    "MercadoPago": {
      "BaseUrl": "https://api.mercadopago.com",
      "AccessToken": "replace-with-access-token",
      "WebhookSecret": "replace-with-secret"
    }
  }
}
